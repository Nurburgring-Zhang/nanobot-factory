# Nanobot Factory 环境变量配置

# === 服务器配置 ===
# 监听端口
NANOBOT_PORT=8001
# 监听地址 (0.0.0.0=所有网卡, 127.0.0.1=仅本地)
NANOBOT_HOST=127.0.0.1
# 数据库路径
DATABASE_PATH=./data/nanobot.db

# === CORS (跨域) 配置 ===
# 允许的来源域名，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8001
# 设为true允许所有来源（仅开发环境！）
CORS_ALLOW_ALL=false

# === API 密钥认证 ===
# API Keys，多个用逗号分隔。留空=开发模式(不强制认证)
API_KEYS=
# HTTP Header名称
API_KEY_HEADER=X-API-Key

# === 速率限制 ===
# 每个客户端每分钟最大请求数
RATE_LIMIT_REQUESTS=100
# 速率限制窗口(秒)
RATE_LIMIT_WINDOW=60

# === ComfyUI 配置 ===
# ComfyUI服务器地址
COMFYUI_URL=http://127.0.0.1:8188

# === 日志配置 ===
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === 开发模式 ===
# true=跳过认证，开启详细日志
DEV_MODE=true

# === 支付 Provider — Live Mode 凭证 (P6-Fix-C-7) ===
# 模式: mock (默认,无任何外部调用) | live (调用真 SDK)
BILLING_STRIPE_MODE=mock
BILLING_ALIPAY_MODE=mock
BILLING_WECHAT_MODE=mock

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
# sk_test_xxx for sandbox, sk_live_xxx for production
STRIPE_API_KEY=sk_test_replace_me
# whsec_xxx from Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Stripe API base (default https://api.stripe.com/v1); only override for testing
# STRIPE_API_BASE=https://api.stripe.com/v1

# --- Alipay (https://open.alipay.com/develop/manage) ---
# 开放平台 APP_ID
ALIPAY_APP_ID=2021000000000000
# 应用私钥 (RSA2, PKCS#1 格式) — 用于签名请求
ALIPAY_PRIVATE_KEY=
# 支付宝公钥 (用于验证 webhook 签名)
ALIPAY_PUBLIC_KEY=
# 异步通知密钥 (mock 默认 alipay_mock_secret; live 模式下由商户后台配置)
ALIPAY_WEBHOOK_SECRET=alipay_mock_secret
# 支付宝网关 (沙箱: https://openapi.alipaydev.com/gateway.do)
ALIPAY_API_BASE=https://openapi.alipay.com/gateway.do

# --- WeChat Pay (https://pay.weixin.qq.com/wiki/doc/api/) ---
# 公众号/小程序 APP_ID
WECHAT_APP_ID=wx0000000000000000
# 商户号 (MCH_ID)
WECHAT_MCH_ID=1234567890
# API 密钥 v2 (32 位)
WECHAT_MCH_KEY=
# 异步通知密钥 (mock 默认 wechat_mock_secret)
WECHAT_WEBHOOK_SECRET=wechat_mock_secret
# 微信支付 API v3 key (32 位,用于 v3 回调解密)
WECHAT_API_V3_KEY=

# === 字段级加密 (P10-E) ===
# 用于加密敏感字段(API Key、PII、支付卡)在内存与磁盘的存储。
# 算法: AES-256-GCM (cryptography 库)。
# 格式: 64-char hex (32 bytes) — 推荐用 `python -c "import secrets;print(secrets.token_hex(32))"` 生成。
# 生产环境请从 KMS / Vault 注入,不要硬编码或提交到 git。
# 缺失时 APIKeyManager.__init__() 在生产模式下立即抛 EncryptionError (fail-fast)。
API_KEY_MASTER_KEY=

# === 初始 admin 密码 (P11-D-1) ===
# 用于首次启动时 bootstrap 默认 admin 账户。生产环境必须设置 (>= 16 字符随机)。
# 之前硬编码的 Admin@2026! 已被移除 (P9-4 finding / P11-D-1 修复)。
# 推荐生成方式: `python -c "import secrets; print(secrets.token_urlsafe(24))"`
# 缺省 + 非测试模式: UnifiedAuthManager.__init__() 抛 AdminConfigError (fail-fast)
# 缺省 + IMDF_TEST_MODE=1: 自动生成 ephemeral 密码 + 写 stderr (一次性)
ADMIN_INITIAL_PASSWORD=

# === 预设账号密码 (P12-B1) ===
# 所有 11 个预设账号的密码全部从 env 注入,严禁硬编码在 source / 部署脚本中。
# 每个 var 必须 >= 12 字符随机。生成: `python -c "import secrets; print(secrets.token_urlsafe(16))"`
# 缺省 + 非测试模式: scripts/init_accounts.py 抛 RuntimeError (fail-fast)
# 缺省 + IMDF_TEST_MODE=1: 自动生成 ephemeral 密码 (每个账号一个, 写 stderr)
# ---- 生产团队 ----
PROD_LEAD_PASSWORD=
QC_LEAD_PASSWORD=
PROD_USER1_PASSWORD=
PROD_USER2_PASSWORD=
PROD_USER3_PASSWORD=
# ---- 众包团队 ----
CROWD_LEAD_PASSWORD=
CROWD_MGR_PASSWORD=
CROWD_QC_PASSWORD=
CROWD_USER1_PASSWORD=
# ---- 需求方 ----
CLIENT1_PASSWORD=
