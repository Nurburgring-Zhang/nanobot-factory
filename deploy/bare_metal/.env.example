# ============================================================================
# IMDF Bare-Metal Environment Configuration (.env.example)
# ============================================================================
#
# Usage:
#   sudo cp .env.example /etc/imdf/imdf.env
#   sudo chmod 600 /etc/imdf/imdf.env
#   sudo chown imdf:imdf /etc/imdf/imdf.env
#
# Every systemd unit in /etc/systemd/system/imdf-*.service sources this file
# via `EnvironmentFile=/etc/imdf/imdf.env`. Do NOT commit secrets to git.
#
# Required secrets (replace before going live):
#   - JWT_SECRET_KEY             (>= 32 bytes random, OWASP A07)
#   - AUDIT_CHAIN_SECRET         (>= 32 bytes random, OWASP A08)
#   - DB_APP_PASSWORD            (Postgres `imdf_app` user password)
#   - OSS_ACCESS_KEY_SECRET      (MinIO root password, OWASP A02)
# ============================================================================

# ─────────────────────────── Project paths ────────────────────────────
IMDF_PROJECT_ROOT=/opt/nanobot-factory
IMDF_VENV=/opt/nanobot-factory/venv
IMDF_DATA_DIR=/opt/nanobot-factory/data
IMDF_LOGS_DIR=/opt/nanobot-factory/logs
IMDF_AUDIT_DIR=/opt/nanobot-factory/data/audit
IMDF_FRONTEND_DIST=/opt/nanobot-factory/frontend-v2/dist

# ─────────────────────────── Server / runtime ──────────────────────────
IMDF_WEB_HOST=0.0.0.0
IMDF_WEB_PORT=8765
UVICORN_LOG_LEVEL=info
LOG_LEVEL=INFO
IMDF_DEBUG=false
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ─────────────────────────── Database (PostgreSQL + pgvector) ──────────
IMDF_P2_DB_URL=postgresql://imdf_app:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/imdf
DB_APP_USER=imdf_app
DB_APP_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=imdf
DB_HOST=127.0.0.1
DB_PORT=5432

# ─────────────────────────── Redis ────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_RESULT_EXPIRES=86400
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=200
CELERY_TASK_DEFAULT_QUEUE=imdf.default
CELERY_HEALTH_REQUIRED=true

# ─────────────────────────── Object Storage (MinIO / S3) ──────────────
OSS_BACKEND=minio
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_BUCKET=imdf-assets
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ROOT_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_ROOT_PASSWORD
MINIO_REGION=us-east-1
MINIO_SECURE=false
OSS_ENDPOINT=127.0.0.1:9000
OSS_BUCKET=imdf-assets
OSS_ACCESS_KEY_ID=CHANGE_ME_MINIO_ROOT_USER
OSS_ACCESS_KEY_SECRET=CHANGE_ME_MINIO_ROOT_PASSWORD
OSS_REGION=cn-hangzhou
OSS_SECURE=false
OSS_PRESIGN_EXPIRES=3600

# ─────────────────────────── Security / JWT ────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_min_32_bytes_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUDIT_CHAIN_SECRET=CHANGE_ME_audit_chain_secret_min_32_bytes_random
AUDIT_CHAIN_DB_PATH=/opt/nanobot-factory/data/audit/audit_chain.db
IMDF_REGISTRATION_ENABLED=true
IMDF_AUTH_RATE_LIMIT=10

# ─────────────────────────── CORS ──────────────────────────────────────
CORS_ALLOW_ORIGINS=https://imdf.example.com,https://app.imdf.example.com
CORS_ALLOW_CREDENTIALS=true

# ─────────────────────────── Rate limiting ────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_ENABLED=true
MAX_CONCURRENT_REQUESTS=200
REQUEST_TIMEOUT_SECONDS=60
MAX_BODY_SIZE_MB=64

# ─────────────────────────── AI providers ─────────────────────────────
AI_PROVIDER_OPENAI_KEY=
AI_PROVIDER_ANTHROPIC_KEY=
AI_PROVIDER_MODELSCOPE_KEY=
AI_PROVIDER_VOLCENGINE_KEY=
AI_PROVIDER_REPLICATE_KEY=
AI_PROVIDER_STABILITY_KEY=
AI_PROVIDER_JIMENG_PATH=/usr/local/bin/dreamina
COMFYUI_BASE_URL=http://127.0.0.1:8188
AI_RATE_LIMIT_PER_HOUR=1000
AI_BREAKER_ERROR_THRESHOLD=0.5
AI_BREAKER_COOLDOWN_SECONDS=30
AI_BREAKER_WINDOW_SIZE=20

# ─────────────────────────── Robustness / protection ──────────────────
ENABLE_ROBUSTNESS_MIDDLEWARE=true
WATCHDOG_ENABLED=true
WATCHDOG_SEC=30
MEMORY_MAX_MB=2048
MEMORY_HIGH_MB=1536

# ─────────────────────────── Service ports (gateway + 12 svc) ──────────
# Localhost-only by default; nginx front-end handles public traffic
IMDF_GATEWAY_PORT=8000
IMDF_USER_PORT=8001
IMDF_ASSET_PORT=8002
IMDF_ANNOTATION_PORT=8003
IMDF_CLEANING_PORT=8004
IMDF_SCORING_PORT=8005
IMDF_DATASET_PORT=8006
IMDF_EVALUATION_PORT=8007
IMDF_AGENT_PORT=8008
IMDF_WORKFLOW_PORT=8009
IMDF_NOTIFICATION_PORT=8010
IMDF_SEARCH_PORT=8011
IMDF_COLLECTION_PORT=8012

# ─────────────────────────── Celery worker / beat ─────────────────────
CELERY_CONCURRENCY=4
CELERY_QUEUES=imdf.default,imdf.video,imdf.cpu,imdf.index,imdf.network
CELERY_LOG_LEVEL=info

# ─────────────────────────── Monitoring / tracing ─────────────────────
JAEGER_AGENT_HOST=127.0.0.1
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1
PROMETHEUS_MULTIPROC_DIR=/opt/nanobot-factory/data/prometheus
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
LOKI_URL=http://127.0.0.1:3100/loki/api/v1/push

# ─────────────────────────── Notification / SMTP ─────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=imdf@example.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=noreply@imdf.example.com
SMTP_USE_TLS=true

# Webhook URLs (Slack / PagerDuty)
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# ─────────────────────────── Admin bootstrap (first run) ──────────────
IMDF_ADMIN_USERNAME=admin
IMDF_ADMIN_PASSWORD=CHANGE_ME_admin_password_first_run

# ─────────────────────────── Feature flags ────────────────────────────
IMDF_ENABLE_ANNOTATION=true
IMDF_ENABLE_CLEANING=true
IMDF_ENABLE_SCORING=true
IMDF_ENABLE_AGENT=true
IMDF_ENABLE_WORKFLOW=true