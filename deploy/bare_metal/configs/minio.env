# ============================================================================
# minio.env — IMDF MinIO Server environment file
# ----------------------------------------------------------------------------
# Sourced by /etc/systemd/system/minio.service. Edit CHANGE_ME_* values.
# ============================================================================

# Root credentials (rotate every 90 days; treat as production secrets)
MINIO_ROOT_USER=CHANGE_ME_minio_root_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password_min_8_chars

# Single-host single-drive; for HA use MINIO_VOLUMES with 4 erasure-coded paths
MINIO_VOLUMES=/var/lib/minio

# API + console endpoints
MINIO_OPTS="--address :9000 --console-address :9001"

# TLS (set true after copying certs into /etc/minio/certs/)
MINIO_SECURE=false

# Cache + observability
MINIO_CACHE_DRIVES=/var/lib/minio/cache
MINIO_CACHE_QUOTA=80
MINIO_PROMETHEUS_AUTH_TYPE=public

# Default region + site
MINIO_REGION_NAME=us-east-1
MINIO_SITE_NAME=imdf-site-1

# Browser auto-redirect (off — clients should use signed URLs)
MINIO_BROWSER_REDIRECT_URL=https://imdf.example.com/minio/ui