backend/.env
# P21 P4 P2 OWASP A02 fix: real env configs (not templates) must never
# be committed. Templates carry the `.example` suffix; the bare names
# below are live deploy-time configs that contain real secrets.
.env.production
.env.template
frontend-v2/.env.production
# P22-P2-cleanup: also block any *.env at repo root, deploy/*/configs/,
# and frontend-v2 root — these were missed in the P21 P4 P2 pass.
# Templates still commit as `*.env.example` (see existing rules above).
*.env
!*.env.example
!deploy/bare_metal/configs/*.env.example
deploy/bare_metal/configs/*.env
!deploy/bare_metal/configs/minio.env.example

