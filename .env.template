# ============================================
# 智影数据工场 — 环境变量模板 (.env.template)
# ============================================
# 复制此文件为 .env 并根据环境修改
# cp .env.template .env

# === 安全配置 (必须修改) ===
# JWT密钥 — 生产环境必须使用强随机密钥
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production

# === 服务器配置 ===
NANOBOT_PORT=8899
NANOBOT_HOST=0.0.0.0

# === 数据库 ===
DATABASE_PATH=./data/imdf.db

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8899
CORS_ALLOW_ALL=false

# === API 密钥 ===
API_KEYS=
API_KEY_HEADER=X-API-Key

# === 速率限制 ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# === ComfyUI ===
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_PORT=8188

# === 模型配置 ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === 日志 ===
LOG_LEVEL=INFO

# === 开发模式 ===
DEV_MODE=true
