{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/imdf-app.tsx",
    "src/imdf-main.tsx",
    "src/vite-env.d.ts",
    "src/stores/**/*.ts",
    "src/stores/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/providers/**/*.ts",
    "src/providers/**/*.tsx",
    "src/services/**/*.ts",
    "src/services/**/*.tsx",
    "src/types/**/*.ts",
    "src/types/**/*.tsx",
    "src/theme/**/*.ts",
    "src/theme/**/*.tsx",
    "src/utils/**/*.ts",
    "src/utils/**/*.tsx",
    "src/styles/**/*.css"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/nodes/**"
  ]
}
