# ============================================================================
# IMDF Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   vim .env

# --- Security ---
# CHANGE THIS! Generate a strong random key:
#   openssl rand -hex 32
JWT_SECRET_KEY=imdf_secret_change_me

# --- Database ---
# SQLite is the default (no extra setup). For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/imdf

# --- Server ---
IMDF_WEB_HOST=0.0.0.0
IMDF_WEB_PORT=8765

# --- Admin Account (first-run) ---
# Create the first admin account by running:
#   python scripts/create_admin.py --username admin --password YOUR_SECURE_PASSWORD
# Or set these env vars and it'll be auto-created on startup:
# IMDF_ADMIN_USERNAME=admin
# IMDF_ADMIN_PASSWORD=changeme

# --- Registration ---
# Set to "false" to disable public registration (admin-only user creation)
IMDF_REGISTRATION_ENABLED=true

# --- Rate Limiting ---
# Auth endpoints: max requests per minute per IP
IMDF_AUTH_RATE_LIMIT=10

# --- CORS (production) ---
# Change from * to your actual domain(s) in production:
# IMDF_CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# --- Cloud / API Keys ---
# Fill in your provider API keys as needed:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# REPLICATE_API_KEY=r8_...
# STABILITY_API_KEY=sk-...
# COMFYUI_BASE_URL=http://localhost:8188

# --- Logging ---
# Log level: debug, info, warning, error
IMDF_LOG_LEVEL=info

# --- AI Provider (P2-3-W2) ---
# 5 个 provider 的 API keys (没有 key 也能跑, 自动降级 mock)
# AI_PROVIDER_OPENAI_KEY=sk-...
# AI_PROVIDER_MODELSCOPE_KEY=ms-...
# AI_PROVIDER_VOLCENGINE_KEY=...
# AI_PROVIDER_JIMENG_PATH=/usr/local/bin/dreamina

# 每用户每小时最大调用次数 (默认 1000)。设为 0 表示不限制
AI_RATE_LIMIT_PER_HOUR=1000

# 自定义单价 (USD per 1K tokens), 覆盖内置 DEFAULT_COST_TABLE
# 格式: protocol:model=input_price,output_price;protocol2:*=in,out
# 例: AI_COST_PER_1K_TOKENS=openai-compatible:gpt-4o=0.005,0.015;volcengine:*=0.001,0.002
AI_COST_PER_1K_TOKENS=

# Circuit breaker: error_rate 阈值 (默认 0.5), cooldown 秒数 (默认 30)
AI_BREAKER_ERROR_THRESHOLD=0.5
AI_BREAKER_COOLDOWN_SECONDS=30
AI_BREAKER_WINDOW_SIZE=20
