{
  "name": "nanobot-factory",
  "version": "1.0.0",
  "type": "module",
  "description": "Windows-based AI Agent Production Platform with Multimedia Database Management",
  "main": "dist/main/main.js",
  "author": "MiniMax Agent",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:renderer && concurrently -k \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:electron\"",
    "start:backend": "cd backend && python -m uvicorn server:app --host 127.0.0.1 --port 8001 --reload",
    "start:frontend": "vite --host 0.0.0.0",
    "start:electron": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite --host 0.0.0.0",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"Linting not configured\" && exit 0"
  },
  "dependencies": {
    "@pixi/app": "6.5.10",
    "@pixi/core": "6.5.10",
    "@pixi/display": "6.5.10",
    "@pixi/loaders": "6.5.10",
    "@pixi/math": "6.5.10",
    "@pixi/sprite": "6.5.10",
    "@pixi/ticker": "6.5.10",
    "@pixi/utils": "6.5.10",
    "@pixiv/three-vrm": "3.0.0",
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "8.18.0",
    "@tanstack/react-query": "5.17.0",
    "@types/leaflet": "^1.9.21",
    "axios": "1.6.2",
    "buffer": "6.0.3",
    "chokidar": "3.5.3",
    "clsx": "2.0.0",
    "date-fns": "2.30.0",
    "electron-log": "5.0.1",
    "electron-store": "8.1.0",
    "eventemitter3": "5.0.4",
    "events": "3.3.0",
    "framer-motion": "10.16.5",
    "glob": "10.3.10",
    "leaflet": "^1.9.4",
    "lucide-react": "0.294.0",
    "markdown-it": "14.0.0",
    "object-assign": "4.1.1",
    "pixi-live2d-display": "0.4.0",
    "pixi.js": "6.5.10",
    "process": "0.11.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "6.20.0",
    "recharts": "2.10.3",
    "tailwind-merge": "2.1.0",
    "three": "0.160.1",
    "url": "0.11.4",
    "util": "0.12.5",
    "uuid": "9.0.1",
    "ws": "8.14.2",
    "yaml": "2.3.4",
    "zustand": "4.4.7"
  },
  "devDependencies": {
    "@types/markdown-it": "13.0.7",
    "@types/node": "20.10.0",
    "@types/react": "18.2.39",
    "@types/react-dom": "18.2.17",
    "@types/uuid": "9.0.7",
    "@types/ws": "8.5.10",
    "@vitejs/plugin-react": "4.2.0",
    "autoprefixer": "10.4.16",
    "concurrently": "8.2.2",
    "electron": "27.1.0",
    "electron-builder": "24.9.1",
    "postcss": "8.4.32",
    "tailwindcss": "3.3.6",
    "typescript": "5.3.2",
    "vite": "5.0.4",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "com.nanobot.factory",
    "productName": "Nanobot Factory",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "skills",
        "to": "skills"
      },
      {
        "from": "plugins",
        "to": "plugins"
      }
    ]
  }
}
