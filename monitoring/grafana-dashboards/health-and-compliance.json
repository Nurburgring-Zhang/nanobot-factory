{
  "title": "nanobot-factory — Health Probes & GDPR Compliance",
  "uid": "imdf-health-compliance",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "tags": ["imdf", "health", "compliance", "p19-e3"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "Prometheus"},
        "query": "label_values(health_probe_status, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Health Status (up=1 / unknown=2 / down=0)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "health_probe_status{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "UP", "color": "green"}}},
            {"type": "value", "options": {"2": {"text": "UNKNOWN", "color": "gray"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1},
              {"color": "gray", "value": 2}
            ]
          },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Health Probe Latency (ms) per Service",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "health_probe_latency_ms{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Healthy Services (current)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [
        {"expr": "sum(health_probe_status == 1)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 15}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unhealthy Services (current)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "targets": [
        {"expr": "sum(health_probe_status == 0)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Health Probe Success Rate (per service)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "rate(health_probe_up_total[5m]) / (rate(health_probe_up_total[5m]) + rate(health_probe_fail_total[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          }
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "GDPR Erasures — last 1h",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum(increase(gdpr_erasure_total{outcome=\"success\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "GDPR Erasures — failures (1h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "expr": "sum(increase(gdpr_erasure_total{outcome=\"failure\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GDPR Erasure Duration — P50 / P95 (ms)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gdpr_erasure_duration_ms_total[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gdpr_erasure_duration_ms_total[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"drawStyle": "line", "lineInterpolation": "smooth"}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GDPR Records Erased (1h rate)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(gdpr_erasure_records_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "fillOpacity": 20}}
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Avg GDPR Erasure Duration (last 5m)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "sum(rate(gdpr_erasure_duration_ms_total[5m])) / sum(rate(gdpr_erasure_observations_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 2000}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Audit Chain Unavailable (1h)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 28},
      "targets": [
        {
          "expr": "sum(increase(imdf_audit_chain_unavailable_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "none"}
    }
  ]
}