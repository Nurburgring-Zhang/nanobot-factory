{
  "title": "nanobot-factory Overview",
  "uid": "imdf-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "tags": ["imdf", "overview"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "QPS (total)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(imdf_requests_total[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "P99 Latency (s)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum(rate(imdf_request_latency_seconds_bucket[5m])) by (le))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (%)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(imdf_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(imdf_requests_total[5m]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Connections",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "sum(imdf_active_connections)", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate by microservice",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum by (microservice) (rate(imdf_requests_total[1m]))", "legendFormat": "{{microservice}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P95 latency by microservice",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, microservice) (rate(imdf_request_latency_seconds_bucket[5m])))", "legendFormat": "{{microservice}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory RSS by microservice",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum by (microservice) (imdf_memory_rss_bytes)", "legendFormat": "{{microservice}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue depth & running tasks",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum(imdf_queue_depth)", "legendFormat": "queue_depth", "refId": "A"},
        {"expr": "sum(imdf_running_tasks)", "legendFormat": "running_tasks", "refId": "B"}
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent error logs (Loki)",
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [
        {"expr": "{namespace=~\"imdf|production\"} |~ \"(?i)error|exception|traceback\"", "refId": "A"}
      ]
    }
  ]
}
